# Copy to .env.ds-meal (gitignored) and fill in real values. Never commit real keys.
#
# IMPORTANT: ds-meal uses the Claude MAX subscription via Claude Agent SDK — it does NOT
# need a metered ANTHROPIC_API_KEY. The SDK authenticates via the Claude Code OAuth
# credentials already present on the host. No Anthropic env var is set here by design.

# Clerk auth — dedicated "DS-Meal" Development instance, Google provider only.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_JWKS_URL=https://REPLACE_ME.clerk.accounts.dev/.well-known/jwks.json
CLERK_SIGN_IN_URL=https://REPLACE_ME.accounts.dev/sign-in

# Database — SQLite file bind-mounted at /app/data/ in the container.
# Async driver prefix (aiosqlite) required for the FastAPI async engine.
DATABASE_URL=sqlite+aiosqlite:////app/data/ds-meal.db

# Runtime
DEBUG=false
LOG_LEVEL=info
